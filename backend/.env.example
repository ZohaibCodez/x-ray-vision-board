# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# === OpenRouter ===
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=z-ai/glm-4.5-air:free
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=XRayVision AI
OPENROUTER_TIMEOUT_SECONDS=60

# === Hugging Face ===
HF_TOKEN=your-huggingface-read-token

# === JWT ===
JWT_SECRET=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# === Model Config ===
YOLO_WEIGHTS_PATH=models/fracture_yolov8.pt
ALLOW_GENERIC_YOLO_WEIGHTS=false
FRACTURE_CLASSIFIER_ENABLED=true
FRACTURE_CLASSIFIER_MODEL_NAME=prithivMLmods/Bone-Fracture-Detection
WOUND_MODEL_NAME=PayamFard123/dermaintel-wound-classifier
CONFIDENCE_THRESHOLD=0.40

# === CORS ===
FRONTEND_URL=http://localhost:5173
# For production, add your deployed frontend URL(s) — comma-separated
# ALLOWED_ORIGINS=https://myapp.vercel.app,https://myapp.com

# === Performance ===
# Set to true on free-tier hosts (<=512 MB RAM) to skip model preloading
# DISABLE_PRELOAD=false
