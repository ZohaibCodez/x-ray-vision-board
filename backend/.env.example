JWT_EXPIRY_HOURS=24

# === Model Config ===
YOLO_WEIGHTS_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.40

# === CORS ===
FRONTEND_URL=http://localhost:5173
